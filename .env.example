# Database (Neon Postgres)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/forge_gtm?sslmode=require

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...
RESEND_INBOUND_DOMAIN=replies.yourdomain.com

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Sending domain
SENDING_DOMAIN=outreach.yourdomain.com
DEFAULT_FROM_NAME=Your Name
DEFAULT_FROM_EMAIL=you@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=https://forge-gtm.pages.dev
